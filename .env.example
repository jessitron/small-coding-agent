# Local telemetry → Boswell collector container (http://localhost:4318).
# See notes/telemetry.md. Copy to .env (gitignored). These are the LOCAL dev
# values; `local-dev-token` is the localhost-only ingest token the Boswell
# collector validates (not a secret). Prod values are set on the AgentCore
# runtime by scripts/deploy.sh, not here.
OTEL_SERVICE_NAME=trainer-agent
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer local-dev-token
