{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AssumeByAgentCore",
      "Effect": "Allow",
      "Principal": { "Service": "bedrock-agentcore.amazonaws.com" },
      "Action": "sts:AssumeRole",
      "Condition": {
        "StringEquals": { "aws:SourceAccount": "414852377253" },
        "ArnLike": { "aws:SourceArn": "arn:aws:bedrock-agentcore:us-west-2:414852377253:*" }
      }
    }
  ]
}
