# Keep the build context small and the image clean.
.git
.venv
venv
__pycache__
*.py[cod]
*.egg-info

# Secrets never go in the image (fetched at runtime from Secrets Manager).
.env
.env.*
!.env.example

# Agent workspace (cloned repos / working trees)
workspace/

# Docs & notes aren't needed at runtime
notes/
design/
*.md
